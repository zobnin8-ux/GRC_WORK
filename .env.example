# GRC — пример переменных окружения.
# Скопируй в .env и заполни реальными значениями. .env в гит НЕ коммитится.
# Секреты (токены/ключи) — только здесь как плейсхолдеры, реальные значения в .env / секретах платформы.

# --- Supabase ---
# В Edge Functions SUPABASE_URL и SUPABASE_SERVICE_ROLE_KEY прокидываются платформой
# автоматически — отдельно задавать не нужно. Эти значения нужны для локальных
# скриптов / фронта.
SUPABASE_URL=https://kuuxaubnbwbwjdttvhom.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Фронт (Next.js дашборд) ---
# Публично-безопасны: попадают в клиентский бандл. Anon-ключ — можно. Эти же
# значения задать в Vercel → Project Settings → Environment Variables.
NEXT_PUBLIC_SUPABASE_URL=https://kuuxaubnbwbwjdttvhom.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Pipedrive (CRM) ---
# Личный API-токен аккаунта. СЕКРЕТ — не коммитить реальное значение.
PIPEDRIVE_API_TOKEN=
# Хэш кастомного поля сделки external_key (НЕ секрет — идентификатор поля в API).
# Через него делаем идемпотентный upsert сделки (защита от дублей на стороне Pipedrive).
PIPEDRIVE_EXTERNAL_KEY_FIELD=612b77e2ccea2f5602b0b9a1549898e6482daebc
